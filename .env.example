# =============================================================================
# Tutor — Environment Configuration Example
# Copy this file to .env and fill in your actual API keys.
# =============================================================================

# ---------- General ----------
TUTOR_ENV=development
TUTOR_LOG_LEVEL=INFO
TUTOR_LANGUAGE=zh
TUTOR_DATA_DIR=./data

# ---------- Server ----------
TUTOR_HOST=0.0.0.0
TUTOR_PORT=8000
TUTOR_CORS_ORIGINS=http://localhost:3010,http://127.0.0.1:3010

# ---------- LLM: Default Provider ----------
# Choose one of: openai, anthropic, deepseek, azure_openai, ollama, custom
TUTOR_LLM_PROVIDER=openai
TUTOR_LLM_MODEL=gpt-4o-mini
TUTOR_LLM_API_KEY=
TUTOR_LLM_BASE_URL=https://api.openai.com/v1
TUTOR_LLM_TEMPERATURE=0.7
# TUTOR_LLM_MAX_TOKENS caps the *output* per response, not the input context.
# 4096 is fine for short answers; raise to 8192 / 16384 if you have a
# long-context model and want longer generations.
TUTOR_LLM_MAX_TOKENS=4096

# ---------- LLM: Alternative Providers (optional) ----------
# Used for routing specific tasks to specific models
# TUTOR_AGENT_LLM_MODEL=gpt-4o
# TUTOR_AGENT_LLM_API_KEY=
# TUTOR_AGENT_LLM_BASE_URL=https://api.openai.com/v1

# ---------- Embedding (for RAG) ----------
# OpenRouter is OpenAI-API-compatible — set TUTOR_EMBED_API_KEY to your
# OpenRouter key and TUTOR_EMBED_BASE_URL to https://openrouter.ai/api/v1.
# Free NVIDIA Nemotron embed (multimodal) is available at
#   nvidia/llama-nemotron-embed-vl-1b-v2:free
TUTOR_EMBED_PROVIDER=openai
TUTOR_EMBED_MODEL=text-embedding-3-small
TUTOR_EMBED_API_KEY=
TUTOR_EMBED_BASE_URL=https://api.openai.com/v1
TUTOR_EMBED_DIMENSIONS=0

# ---------- RAG ----------
TUTOR_RAG_PROVIDER=llamaindex
TUTOR_RAG_CHUNK_SIZE=512
TUTOR_RAG_CHUNK_OVERLAP=50
TUTOR_RAG_TOP_K=5

# ---------- Knowledge Base ----------
TUTOR_KB_DEFAULT=ai_introduction
# TUTOR_KB_DIR — default resolves to <package>/knowledge_base via __file__.
# Only override if your knowledge_base lives elsewhere.
# TUTOR_KB_DIR=/custom/path/to/knowledge_base

# ---------- Manim (Video Generation) ----------
TUTOR_MANIM_ENABLED=true
TUTOR_MANIM_QUALITY=l          # l=low (480p15), m=medium (720p30), h=high (1080p60)
TUTOR_MANIM_TIMEOUT=600        # seconds
# TUTOR_MANIM_OUTPUT_DIR / TUTOR_MANIM_TEMP_DIR default to <package>/manim_render/{output,temp}.
# TUTOR_MANIM_OUTPUT_DIR=/custom/path/manim_output
# TUTOR_MANIM_TEMP_DIR=/custom/path/manim_temp
TUTOR_CODE_RETRY_MAX_ATTEMPTS=4

# ---------- Web Search (optional) ----------
# Providers: duckduckgo | searxng | bing | mcp
#   mcp = delegate to a configured MCP server (see .mcp.json + TUTOR_MCP_*)
TUTOR_WEB_SEARCH_ENABLED=true
TUTOR_WEB_SEARCH_PROVIDER=mcp
TUTOR_WEB_SEARCH_MAX_RESULTS=5

# ---------- MCP (Model Context Protocol) ----------
# Path to MCP config (JSON). When unset, defaults to "./.mcp.json".
# TUTOR_MCP_CONFIG_PATH=./.mcp.json
# Used when TUTOR_WEB_SEARCH_PROVIDER=mcp:
# TUTOR_WEB_SEARCH_MCP_SERVER=MiniMax
# TUTOR_WEB_SEARCH_MCP_TOOL=web_search

# ---------- MiniMax API Key (consumed by .mcp.json via ${MINIMAX_API_KEY}) ----------
# Token-plan MCP key — same key as your MiniMax LLM subscription.
# Get one at: https://platform.minimaxi.com/
MINIMAX_API_KEY=

# ---------- Anti-Hallucination ----------
TUTOR_ANTI_HALLUCINATION_ENABLED=true
TUTOR_FACT_CHECK_CONFIDENCE_THRESHOLD=0.7
TUTOR_CONTENT_SAFETY_ENABLED=true

# ---------- Profile ----------
TUTOR_PROFILE_MIN_CONVERSATION_ROUNDS=2
TUTOR_PROFILE_UPDATE_INTERVAL_SECONDS=300

# ---------- Streaming ----------
TUTOR_STREAM_CHUNK_SIZE=20      # characters per chunk
TUTOR_STREAM_QUEUE_MAX_SIZE=1000

# ---------- Multi-user (optional, MVP disabled) ----------
TUTOR_MULTI_USER_ENABLED=false
TUTOR_AUTH_SECRET=
